# Meta WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose_a_secure_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# AI Provider
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=
AI_MODEL=openai/gpt-4o-mini

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Config
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=any-long-random-secret

# Business Profile
BUSINESS_NAME=Your Business Name
BUSINESS_PHONE=+910000000000
BUSINESS_EMAIL=hello@example.com
BUSINESS_ADDRESS=Your business address
BUSINESS_HOURS=Mon-Fri 9am-6pm
BUSINESS_PRIMARY_GOAL=Answer customer questions and help with bookings
ASSISTANT_ALLOWED_TASKS=Answer FAQs, collect leads, help with bookings, and escalate to a human when needed
ASSISTANT_ESCALATION_RULES=Escalate when the user asks for a human, asks for pricing or policy exceptions, or when the answer is uncertain
ASSISTANT_SALES_NOTES=Add pricing, product fit, scarcity, gifting, and qualification notes here
ASSISTANT_TONE=Friendly and professional
ASSISTANT_LANGUAGE=English
